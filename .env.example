# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
# Reasoning effort for GPT-5 / o-series / gpt-5.4-* models: none, minimal, low, medium, high, xhigh
# Leave empty to omit the parameter (model default). xhigh costs 3-5x more than low.
LLM_REASONING_EFFORT=

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Role-scoped LLM groups (optional) =====
# Each role falls back per-field to the LLM_* globals above when unset.
# Set none of these to keep current behavior.

# BUILDER role — heavy reasoning during agent profile build
#BUILDER_LLM_API_KEY=
#BUILDER_LLM_BASE_URL=
#BUILDER_LLM_MODEL_NAME=

# SWARM role — bulk OASIS simulation (large agent population)
#SWARM_LLM_API_KEY=
#SWARM_LLM_BASE_URL=
#SWARM_LLM_MODEL_NAME=

# JUDGE role — final ReACT report agent (deep reasoning, low volume)
#JUDGE_LLM_API_KEY=
#JUDGE_LLM_BASE_URL=
#JUDGE_LLM_MODEL_NAME=

# ===== Pre-simulation web research (optional, opt-in) =====
# Set RESEARCH_ENABLED=true and provide TAVILY_API_KEY to enable.
# Default-off; approximate cost ~$0.60 per simulation at default settings.
#RESEARCH_ENABLED=false
#RESEARCH_BASE_K=3
#MAX_RESEARCH_QUERIES_PER_AGENT=20
#RESEARCH_CACHE_TTL_HOURS=24
#TAVILY_API_KEY=